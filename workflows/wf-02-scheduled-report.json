        "cardContent": "={{ $('② 截断格式化').first().json.payload }}",
        "cardColor": "blue"
      },
      "id": "feishu", "name": "③ 飞书卡片播报", "type": "@lixiongwei/n8n-nodes-feishu.feishu", "typeVersion": 2,
      "position": [250, 300],
      "credentials": { "feishuApi": { "id": "PLACEHOLDER", "name": "飞书 Feishu account" } }
    }
  ],
  "connections": { "⏰ 每天 9:00": { "main": [[{ "node": "① 拉取数据", "type": "main", "index": 0 }]] }, "① 拉取数据": { "main": [[{ "node": "② 截断格式化", "type": "main", "index": 0 }]] }, "② 截断格式化": { "main": [[{ "node": "③ 飞书卡片播报", "type": "main", "index": 0 }]] } },
  "pinData": {}, "versionId": "1.0.0", "active": false, "settings": {},
  "tags": [{ "name": "报表" }, { "name": "自动化" }, { "name": "每日播报" }]
